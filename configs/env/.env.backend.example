# ======================================================================
# DJANGO APPLICATION CONFIGURATION
# Variables consumed by the Django backend and related worker services.
# These values are environment-specific and should not be committed with
# real credentials in version control.
# ======================================================================

# Django settings module. For development, use config.settings.dev.
# Production should set config.settings.prod or another environment.
DJANGO_SETTINGS_MODULE=config.settings.dev

# Secret key for Django cryptographic signing. Replace locally and in
# prod with unique, high-entropy values. `scripts/bootstrap/bootstrap-secrets.sh`
# will generate this when it is missing or still the placeholder value.
DJANGO_SECRET_KEY=replace_me_with_a_very_secret_value

# Enables Django's debug mode. Always set to False in production.
DJANGO_DEBUG=True

# Comma-separated list of allowable hosts. Override with production
# domains when deploying.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,demoisd.localhost


# ======================================================================
# DATABASE CONFIGURATION
# Use a single DATABASE_URL (12-factor style). Example values:
#
# Local Docker runtime connecting to Postgres on host:
#   postgres://user:password@host.docker.internal:5432/dbname
#
# Production container runtime connecting to managed Postgres:
#   postgres://prod_user:prod_pass@db.example.com:5432/prod_db
# ======================================================================

DATABASE_URL=postgres://user:password@host.docker.internal:5432/dbname


# ======================================================================
# CACHING / QUEUES (PLACEHOLDER)
# Uncomment when Redis or Celery workers are introduced.
#
# REDIS_URL=redis://localhost:6379/0
# CACHE_URL=redis://localhost:6379/1
# BROKER_URL=redis://localhost:6379/2
# ======================================================================


# ======================================================================
# SECURITY / JWT / PORTALS
# ======================================================================

# Paths to JWT key pairs used for signing tokens. Provide absolute paths
# or use secret stores in production.
JWT_PRIVATE_KEY_PATH=/secrets/jwt/private.pem
JWT_PUBLIC_KEY_PATH=/secrets/jwt/public.pem

# Default portal slug to load when none specified.
DEFAULT_PORTAL_SLUG=default

# Browser-visible environment path prefix.
# Local development can mirror the tenant URL shape with `/dev`.
# Deployed tenant environments should use the public environment path such as
# `/prod`, `/sandbox`, or `/training`.
APP_ENV_PATH_PREFIX=/dev

# Optional: list of trusted origins, log level, etc.
# DJANGO_LOG_LEVEL=INFO
# For tenant-facing deployments behind a shared public origin, trust the public
# tenant host rather than an internal backend hostname. Example:
# DJANGO_CSRF_TRUSTED_ORIGINS=https://demoisd.inventoryk12.com

# Production security toggles (optional defaults in prod settings).
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SECURE_HSTS_SECONDS=0
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
# DJANGO_SECURE_HSTS_PRELOAD=False

# CORS allow-list for production (comma-separated).
# If the browser sees one shared public tenant origin for app + API, CORS is
# usually unnecessary. Only set this when the browser-facing origins differ.
# DJANGO_CORS_ALLOWED_ORIGINS=https://demoisd.inventoryk12.com
