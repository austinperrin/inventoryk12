# ======================================================================
# FRONTEND CONFIGURATION
# Variables consumed by the Vite/React frontend. Copy to `.env.frontend`
# and adjust per environment.
# ======================================================================

# Base URL for API requests.
# Local Docker-first development should use a tenant-style localhost host and
# include the environment path prefix:
#   http://demoisd.localhost:8000/dev
#
# Tenant-facing deployed environments should prefer the shared public tenant
# origin rather than a backend server hostname. Example:
#   https://demoisd.inventoryk12.com/prod
#
# The browser should talk to one public tenant origin while edge/gateway
# routing sends page traffic to the frontend server and `/api/` traffic to the
# backend server.
VITE_API_BASE_URL=http://demoisd.localhost:8000/dev

# Browser-visible base path for the current environment.
# Local development should normally use `/dev`.
# Deployed tenant environments should use the environment path on the public
# tenant origin, for example `/prod` or `/sandbox`.
VITE_APP_BASE_PATH=/dev

# Default portal slug loaded when user hits root portal route.
VITE_DEFAULT_PORTAL=default

# Optional monitoring/analytics.
VITE_SENTRY_DSN=

# Enable MSW or other mock APIs during development.
VITE_ENABLE_MOCKS=false
